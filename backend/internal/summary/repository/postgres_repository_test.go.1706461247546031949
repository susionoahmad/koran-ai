func TestListSummaries(t *testing.T) {
	id := uuid.New()
	clusterID := uuid.New()
	now := time.Now()
	rows := &fakeRows{values: [][]any{summaryValues(id, clusterID, now)}}
	repo := &postgresRepository{db: &fakeDB{
		row:  fakeRow{values: []any{int64(1)}},
		rows: rows,
	}}
	got, total, err := repo.ListSummaries(context.Background(), 0, 0)
	if err != nil {
		t.Fatalf("ListSummaries returned error: %v", err)
	}
	if total != 1 || len(got) != 1 || !rows.closed {
		t.Fatalf("unexpected result total=%d got=%+v closed=%v", total, got, rows.closed)
	}
}

