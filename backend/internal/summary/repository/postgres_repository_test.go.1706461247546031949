type fakeDB struct {
	execTag pgconn.CommandTag
	execErr error
	rows    pgx.Rows
	row     pgx.Row
}

func (f *fakeDB) Exec(ctx context.Context, sql string, arguments ...any) (pgconn.CommandTag, error) {
	return f.execTag, f.execErr
}
func (f *fakeDB) Query(ctx context.Context, sql string, args ...any) (pgx.Rows, error) {
	if f.execErr != nil {
		return nil, f.execErr
	}
	return f.rows, nil
}
func (f *fakeDB) QueryRow(ctx context.Context, sql string, args ...any) pgx.Row {
	return f.row
}

type fakeRow struct {
	values []any
	err    error
}

func (f fakeRow) Scan(dest ...any) error {
	if f.err != nil {
		return f.err
	}
	for i := range dest {
		assign(dest[i], f.values[i])
	}
	return nil
}

type fakeRows struct {
	values [][]any
	idx    int
	err    error
	scanErr error
	closed bool
}

func (f *fakeRows) Close()                                       { f.closed = true }
func (f *fakeRows) Err() error                                   { return f.err }
func (f *fakeRows) CommandTag() pgconn.CommandTag                { return pgconn.NewCommandTag("SELECT 1") }
func (f *fakeRows) FieldDescriptions() []pgconn.FieldDescription { return nil }
func (f *fakeRows) Next() bool {
	if f.idx >= len(f.values) {
		return false
	}
	f.idx++
	return true
}
func (f *fakeRows) Scan(dest ...any) error {
	if f.scanErr != nil {
		return f.scanErr
	}
	row := f.values[f.idx-1]
	for i := range dest {
		assign(dest[i], row[i])
	}
	return nil
}
func (f *fakeRows) Values() ([]any, error) { return f.values[f.idx-1], nil }
func (f *fakeRows) RawValues() [][]byte    { return nil }
func (f *fakeRows) Conn() *pgx.Conn        { return nil }

func assign(dest any, value any) {
	switch d := dest.(type) {
	case *uuid.UUID:
		*d = value.(uuid.UUID)
	case *string:
		*d = value.(string)
	case *[]byte:
		*d = value.([]byte)
	case *float64:
		*d = value.(float64)
	case *time.Time:
		*d = value.(time.Time)
	case **time.Time:
		if value == nil {
			*d = nil
		} else {
			v := value.(time.Time)
			*d = &v
		}
	case **uuid.UUID:
		if value == nil {
			*d = nil
		} else {
			v := value.(uuid.UUID)
			*d = &v
		}
	case *bool:
		*d = value.(bool)
	case *int:
		*d = value.(int)
	case *int64:
		*d = value.(int64)
	case *sql.NullString:
		*d = value.(sql.NullString)
	}
}

func summaryValues(id uuid.UUID, clusterID uuid.UUID, now time.Time) []any {
	return []any{id, clusterID, "Headline", "Short", "Medium", "", []byte(`["Point"]`), "gemini", 0.9, now, now, now}
}

func TestCreateSummary(t *testing.T) {
	repo := &postgresRepository{db: &fakeDB{}}
	err := repo.CreateSummary(context.Background(), &entity.Summary{
		ClusterID:    uuid.New(),
		Headline:     "Headline",
		SummaryShort: "Short",
		KeyPoints:    []string{"Point"},
	})
	if err != nil {
		t.Fatalf("CreateSummary returned error: %v", err)
	}
}

func TestCreateSummary_Error(t *testing.T) {
	repo := &postgresRepository{db: &fakeDB{execErr: errors.New("insert failed")}}
	err := repo.CreateSummary(context.Background(), &entity.Summary{ClusterID: uuid.New(), Headline: "H", SummaryShort: "S"})
	if err == nil {
		t.Fatal("expected error")
	}
}

func TestGetSummaryByID(t *testing.T) {
	id := uuid.New()
	clusterID := uuid.New()
	now := time.Now()
	repo := &postgresRepository{db: &fakeDB{row: fakeRow{values: summaryValues(id, clusterID, now)}}}
	got, err := repo.GetSummaryByID(context.Background(), id.String())
	if err != nil {
		t.Fatalf("GetSummaryByID returned error: %v", err)
	}
	if got.ID != id || got.ClusterID != clusterID || len(got.KeyPoints) != 1 {
		t.Fatalf("unexpected summary: %+v", got)
	}
}

func TestGetSummaryByID_NotFoundAndError(t *testing.T) {
	repo := &postgresRepository{db: &fakeDB{row: fakeRow{err: pgx.ErrNoRows}}}
	_, err := repo.GetSummaryByID(context.Background(), uuid.New().String())
	if !errors.Is(err, ErrNotFound) {
		t.Fatalf("expected ErrNotFound, got %v", err)
	}
	repo = &postgresRepository{db: &fakeDB{row: fakeRow{err: errors.New("scan failed")}}}
	_, err = repo.GetSummaryByID(context.Background(), uuid.New().String())
	if err == nil {
		t.Fatal("expected scan error")
	}
}

