func TestListClusterArticles(t *testing.T) {
	articleID := uuid.New()
	sourceID := uuid.New()
	clusterID := uuid.New()
	now := time.Now()
	rows := &fakeRows{values: [][]any{{
		articleID, sourceID, "Title", "slug", "https://example.test", sql.NullString{String: "Author", Valid: true}, "Content",
		now, now, "hash", sql.NullString{String: "image", Valid: true}, true,
		true, sql.NullString{String: "Ekonomi", Valid: true}, 0.8, now,
		true, clusterID, now, now, sql.NullString{}, 1,
	}}}
	repo := &postgresRepository{db: &fakeDB{rows: rows}}
	articles, err := repo.ListClusterArticles(context.Background(), clusterID.String())
	if err != nil {
		t.Fatalf("ListClusterArticles returned error: %v", err)
	}
	if len(articles) != 1 || articles[0].ID != articleID || articles[0].Author == nil || *articles[0].Author != "Author" {
		t.Fatalf("unexpected articles: %+v", articles)
	}
	if !rows.closed {
		t.Fatal("expected rows to close")
	}
}

